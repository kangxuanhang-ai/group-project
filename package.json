{
	"pnpm": {
		"onlyBuiltDependencies": ["@prisma/engines", "prisma", "@nestjs/core"]
	},
	"scripts": {
		"web": "pnpm --filter @en/web dev",
		"server": "pnpm --filter @en/server start:dev",
		"ai": "pnpm --filter @en/server start:dev ai",
		"all": "concurrently \"pnpm run web\" \"pnpm run server\" \"pnpm run ai\""
	},
	"dependencies": {
		"@langchain/core": "^1.1.45",
		"@langchain/deepseek": "^1.0.25",
		"@langchain/langgraph-checkpoint-postgres": "^1.0.1",
		"@types/md5": "^2.3.6",
		"concurrently": "^9.2.1",
		"dayjs": "^1.11.19",
		"marked": "^17.0.6",
		"md5": "^2.3.0"
	},
	"devDependencies": {
		"@types/node": "^25.6.0"
	}
}
